{
  "rules": {
    "wormhole": {
      "$channelId": {
        ".read": true,
        ".write": true,
        "message": {
          ".validate": "newData.val().length < 1000"
        },
        "mood": {
          ".validate": "newData.hasChildren(['sender_id', 'mood', 'sent_at'])"
        },
        "daily_answer": {
          ".validate": "newData.hasChildren(['sender_id', 'answer', 'date', 'sent_at'])"
        }
      }
    },
    "pairing": {
      "$code": {
        ".read": true,
        ".write": true,
        ".validate": "newData.hasChildren(['fcm_token', 'user_id', 'nickname'])"
      }
    }
  }
}
